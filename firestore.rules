rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read a profile (for public detective pages)
      allow read: if request.auth != null;
      // Only the owner can edit their own top-level profile doc
      allow write: if request.auth != null && request.auth.uid == userId;

      // Comment history – any signed-in user can read (shown on public profile)
      match /commentHistory/{commentId} {
        allow read: if request.auth != null;
        // Only the owner can write / delete their own history entries
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Following list – readable by anyone signed in
      match /following/{targetId} {
        allow read: if request.auth != null;
        // Owner manages their list; the followed person can update their own
        // entry (needed when they rename themselves — fan-out username sync)
        allow write: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == targetId);
      }

      // Followers list – readable by anyone signed in
      // A follower entry is written by the person doing the following,
      // so we allow any authenticated user to create/delete entries here
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == followerId);
      }
    }

    // ── Conversations (Direct Messages) ────────────────────────────────────
    match /conversations/{convId} {
      // Only participants can read the conversation doc
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      // Either participant can create the conversation
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      // Either participant can update (e.g. lastMessage, updatedAt)
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        // Only participants of the parent conversation can read messages
        allow read: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        // Only a participant can send a message, and they must be the sender
        allow create: if request.auth != null &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    // ── Stories ────────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         request.auth.token.email == "reagan.paula10@gmail.com");

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Author or story owner can delete a comment
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId ||
           request.auth.uid == get(/databases/$(database)/documents/stories/$(storyId)).data.createdBy);
      }
    }

  }
}
